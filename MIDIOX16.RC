LOG DIALOG DISCARDABLE  0, 0, 186, 79
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Log File"
FONT 8, "MS Sans Serif"
BEGIN
    CONTROL         "Log &Enabled",IDC_LOGENABLED,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,11,11,68,9
    CONTROL         "&Append to Log File",IDC_LOGAPPEND,"Button",
                    BS_AUTOCHECKBOX | WS_TABSTOP,11,25,75,10
    LTEXT           "Log File:",IDC_STATIC,9,48,28,8
    EDITTEXT        IDC_LOGFILE,7,59,172,13,ES_AUTOHSCROLL
    PUSHBUTTON      "&Browse...",IDC_BROWSE,129,42,50,14
    DEFPUSHBUTTON   "OK",IDOK,129,7,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,129,24,50,14
END

KEYBOARD DIALOG DISCARDABLE  0, 65476, 102, 21
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION
CAPTION "Keyboard"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "Off",IDOK,70,3,24,14
    ICON            IDI_ON,IDC_KYBD_LITE,1,1,18,20
    EDITTEXT        IDC_KYBD_CHANNEL,52,4,12,12
    CTEXT           "Channel",IDC_STATIC,21,7,27,8
END


