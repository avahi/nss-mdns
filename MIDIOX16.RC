MENU MENU DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&Log...",                     IDM_LOGFILE
        MENUITEM "Send Syse&x",                 IDM_SYSEXFILE
        MENUITEM "A&bout...",                   IDM_ABOUT
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       IDM_EXIT
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Control Panel...",           IDM_CTLDLG
        MENUITEM "MIDI Status...",              IDM_MSTATUS
    END
    POPUP "&Options"
    BEGIN
        MENUITEM "MIDI &Filter...",             IDM_FILTERDLG
        MENUITEM "&MIDI Devices...",            IDM_MDEVDLG
        MENUITEM SEPARATOR
        POPUP "Middle C Octave"
        BEGIN
            MENUITEM "3",                           IDM_OCT3
            MENUITEM "4",                           IDM_OCT4
            MENUITEM "5",                           IDM_OCT5
            MENUITEM "6",                           IDM_OCT6
        END
        MENUITEM SEPARATOR
        MENUITEM "&Pass SysEx",                 IDM_PASSX
        MENUITEM "&Keyboard",                   IDM_KYBD
    END
    MENUITEM "&Device!",                    IDM_DSDEVICE
    MENUITEM "&Stop!",                      IDM_STARTSTOP
    MENUITEM "&Clear!",                     IDM_CLEAR
END


